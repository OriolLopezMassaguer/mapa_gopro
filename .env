# Root directory containing all GoPro data (media/, passes/, tracks/, video_cache/)
DATA_DIR=/run/media/oriol/Datos/media

# HTTP port the server listens on
# PORT=3001

# Parallel workers for photo EXIF extraction (cheap — can be high)
CACHE_CONCURRENCY=1

# Parallel workers for video GPS extraction.
# Each worker loads the mp4box asm.js module into its own V8 heap (~200-500 MB).
# Running too many simultaneously causes OOM. Keep at 1 unless you have 32+ GB RAM.
VIDEO_CONCURRENCY=1

# Parallel workers for directory scanning
SCAN_CONCURRENCY=16

# Comma-separated filename prefixes to exclude from photo indexing (non-GoPro cameras)
EXCLUDE_PHOTO_PREFIXES=DSC

# Per-file GPS extraction timeout in seconds (default 1000)
# EXTRACTION_TIMEOUT=1000

# Explicit path to ffmpeg binary (leave unset to use ffmpeg from PATH)
# FFMPEG_PATH=
