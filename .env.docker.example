# Copy this file to .env and fill in your values before running docker-compose up.

# Root directory containing all GoPro data (media/, passes/, tracks/, video_cache/).
# On Synology NAS:  DATA_DIR=/volume1/GoPro
# On Linux/Mac:     DATA_DIR=/mnt/nas/gopro
DATA_DIR=/path/to/your/gopro/data

# HTTP port exposed on the host machine
# PORT=3001

# Parallel workers for background telemetry/thumbnail processing (lower on slow NAS disks)
# CACHE_CONCURRENCY=4

# Parallel workers for directory scanning
# SCAN_CONCURRENCY=16

# Comma-separated filename prefixes to exclude from photo indexing (non-GoPro cameras)
# EXCLUDE_PHOTO_PREFIXES=DSC

# Explicit path to ffmpeg binary inside the container (leave unset — bundled by default)
# FFMPEG_PATH=
