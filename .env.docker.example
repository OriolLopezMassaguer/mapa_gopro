# Copy this file to .env and fill in your values before running docker-compose up.

# Root directory containing all GoPro data (media, passes, tracks, cache).
# On Synology NAS:  DATA_DIR=/volume1/GoPro
# On Linux/Mac:     DATA_DIR=/mnt/nas/gopro
DATA_DIR=/path/to/your/gopro/data

# Port exposed on the host machine (default 3001).
# PORT=3001

# Number of parallel workers for background cache processing (default 4).
# Lower this on slow NAS hardware (e.g. CACHE_CONCURRENCY=2).
# CACHE_CONCURRENCY=4
