# Copy this file to .env and fill in your values before running docker-compose up.

# Path to the root directory where GoPro videos are stored.
# On Synology NAS:  VIDEO_DIR=/volume1/GoPro
# On Linux/Mac:     VIDEO_DIR=/mnt/nas/gopro
VIDEO_DIR=/path/to/your/gopro/videos

# Sub-directory inside VIDEO_DIR that contains the actual media files.
MEDIA_SUBDIR=media

# Port exposed on the host machine (default 3001).
# PORT=3001

# Number of parallel workers for background cache processing (default 4).
# Lower this on slow NAS hardware (e.g. CACHE_CONCURRENCY=2).
# CACHE_CONCURRENCY=4
